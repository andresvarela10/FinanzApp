# Database
DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/finance_app"

# JWT Authentication
JWT_SECRET="change-this-to-a-random-secret-minimum-32-characters-long"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# CORS
FRONTEND_URL="http://localhost:3000"

# Market Data APIs (optional - get free keys at their respective sites)
# Alpha Vantage: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=""

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR="./uploads"
